# Which LLM provider to use. mock = no API key needed (canned responses for demo).
LLM_PROVIDER=mock          # gemini | groq | anthropic | mock

GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides (defaults are sensible per provider)
# ANTHROPIC_MODEL=claude-sonnet-5
# ANTHROPIC_MODEL_HIGH=claude-opus-4-8
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile

FRONTEND_ORIGIN=http://localhost:5173
