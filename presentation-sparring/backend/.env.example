# Which LLM provider to use. mock = no API key needed (canned responses for demo).
LLM_PROVIDER=mock          # openai | gemini | groq | anthropic | mock

OPENAI_API_KEY=

# Optional model overrides (defaults are sensible per provider)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL_HIGH=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-5
# ANTHROPIC_MODEL_HIGH=claude-opus-4-8
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile

FRONTEND_ORIGIN=http://localhost:5173
